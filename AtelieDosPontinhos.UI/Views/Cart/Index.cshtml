@model List<AtelieDosPontinhos.UI.Models.CartItemViewModel>

@{
    ViewData["Title"] = "Seu Carrinho de Compras";
}

<div class="container py-5">
    <h2 class="mb-4 text-center fw-bold" style="color: #8a4f91 !important;">🛒 Meu Carrinho de Compras</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded bg-light border">
            <h4 class="text-muted mb-3">Seu carrinho está vazio no momento.</h4>
            <p class="text-secondary mb-4">Adicione produtos artesanais incríveis para começar!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-lg text-white px-4 py-2 rounded-pill shadow" style="background-color: #8a4f91;">
                Ver Produtos
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="text-white text-center" style="background-color: #8a4f91;">
                                <tr>
                                    <th scope="col" class="py-3">Produto</th>
                                    <th scope="col" class="py-3">Preço</th>
                                    <th scope="col" class="py-3">Qtd</th>
                                    <th scope="col" class="py-3">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var nomeProduto = item.Produto.GetType().GetProperty("Nome")?.GetValue(item.Produto)?.ToString()
                                                      ?? item.Produto.GetType().GetProperty("Name")?.GetValue(item.Produto)?.ToString()
                                                      ?? "Produto Artesanal";
                                                      
                                    var precoProduto = Convert.ToDecimal(item.Produto.GetType().GetProperty("Preco")?.GetValue(item.Produto)
                                                      ?? item.Produto.GetType().GetProperty("Price")?.GetValue(item.Produto));
                                                      
                                    var subtotalItem = precoProduto * item.Quantidade;

                                    <tr>
                                        <td class="p-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@item.Produto.CoverImageUrl" alt="@nomeProduto" class="rounded border shadow-sm" style="width: 70px; height: 70px; object-fit: cover;">
                                                <div>
                                                    <h6 class="mb-0 fw-bold text-dark">@nomeProduto</h6>
                                                    <small class="text-muted d-block text-truncate" style="max-width: 200px;">@item.Produto.Descricao</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-semibold text-secondary">R$ @precoProduto.ToString("N2")</td>
                                        <td class="text-center fw-bold text-dark">@item.Quantidade</td>
                                        <td class="text-center fw-bold text-success">R$ @subtotalItem.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @{
                decimal valorTotalGeral = 0;
                foreach (var item in Model)
                {
                    var preco = Convert.ToDecimal(item.Produto.GetType().GetProperty("Preco")?.GetValue(item.Produto) ?? item.Produto.GetType().GetProperty("Price")?.GetValue(item.Produto));
                    valorTotalGeral += (preco * item.Quantidade);
                }
            }

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3 p-4 bg-light border">
                    <h5 class="fw-bold mb-4 border-bottom pb-2 text-dark">Resumo da Compra</h5>
                    
                    <div class="d-flex justify-content-between mb-3 text-secondary">
                        <span>Quantidade total:</span>
                        <span class="fw-semibold">@Model.Sum(x => x.Quantidade) itens</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 pt-3 border-top">
                        <h5 class="fw-bold text-dark mb-0">Valor Total:</h5>
                        <h4 class="fw-bold text-success mb-0">R$ @valorTotalGeral.ToString("N2")</h4>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-success btn-lg rounded-pill fw-bold py-3 shadow-sm">
                            🏁 Finalizar Pedido
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-md rounded-pill fw-semibold py-2">
                            Continuar Comprando
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    @foreach (var item in Model)
    {
        @if (item?.Produto != null)
        {
            var nomeProduto = item.Produto.Nome ?? "Produto Artesanal";
            var precoProduto = item.Produto.Preco;
            var subtotalItem = precoProduto * item.Quantidade;

            <tr>
                <td class="p-3">
                    <div class="d-flex align-items-center gap-3">
                        <img src="@item.Produto.CoverImageUrl" alt="@nomeProduto" class="rounded border shadow-sm" style="width: 70px; height: 70px; object-fit: cover;">
                        <div>
                            <h6 class="mb-0 fw-bold text-dark">@nomeProduto</h6>
                            <small class="text-muted d-block text-truncate" style="max-width: 200px;">@item.Produto.Descricao</small>
                        </div>
                    </div>
                </td>
                <td class="text-center fw-semibold text-secondary">R$ @precoProduto.ToString("N2")</td>
                <td class="text-center fw-bold text-dark">@item.Quantidade</td>
                <td class="text-center fw-bold text-success">R$ @subtotalItem.ToString("N2")</td>
            </tr>
        }
    }
</div>