@{
    ViewData["Title"] = "Minha Conta";
}

<div class="container py-5">
    <!-- Cabeçalho de Boas-Vindas com a Identidade Visual do Ateliê -->
    <div class="row mb-5 align-items-center">
        <div class="col-md-8 text-center text-md-start">
            <h1 class="fw-bold text-dark mb-2">
                <span style="color: #8a4f91;"><i class="bi bi-person-circle"></i></span> Área do Usuário
            </h1>
            <p class="text-muted fs-5 m-0">Bem-vindo ao seu painel, <strong style="color: #8a4f91;">@User.Identity?.Name</strong>! Aqui você acompanha suas compras e gerencia seu perfil.</p>
        </div>
        <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger px-4 rounded-pill fw-bold shadow-sm">
                <i class="bi bi-box-arrow-right"></i> Sair da Conta
            </a>
        </div>
    </div>

    <!-- Cards de Resumo e Atalhos -->
    <div class="row g-4 mb-5">
        <!-- Card 1: Último Pedido -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-info">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-3 bg-info bg-opacity-10 text-info rounded-3 me-3">
                        <i class="bi bi-truck fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold m-0 text-dark">Último Pedido</h5>
                        <small class="text-muted">Pedido #1024</small>
                    </div>
                </div>
                <p class="text-muted small mb-2">1x Fronha Floral Rosa</p>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">A caminho</span>
                    <a href="#" class="text-decoration-none small fw-bold" style="color: #8a4f91;">Detalhes →</a>
                </div>
            </div>
        </div>

        <!-- Card 2: Carrinho Atual -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-warning">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-3 bg-warning bg-opacity-10 text-warning rounded-3 me-3">
                        <i class="bi bi-cart3 fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold m-0 text-dark">Seu Carrinho</h5>
                        <small class="text-muted">Itens reservados</small>
                    </div>
                </div>
                <p class="text-muted small mb-2">Você possui itens aguardando finalização.</p>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="fw-bold text-dark">R$ 0,00</span>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-sm text-white px-3 rounded-pill fw-bold shadow-sm" style="background-color: #8a4f91;">
                        Ver Itens
                    </a>
                </div>
            </div>
        </div>

        <!-- Card 3: Dados de Acesso -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-purple" style="border-left-color: #8a4f91 !important;">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-3 bg-light text-purple rounded-3 me-3" style="color: #8a4f91;">
                        <i class="bi bi-shield-lock fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold m-0 text-dark">Segurança</h5>
                        <small class="text-muted">Dados de login</small>
                    </div>
                </div>
                <p class="text-muted small mb-2">E-mail: @User.Identity?.Name</p>
                <div class="mt-auto">
                    <button class="btn btn-sm btn-outline-secondary w-100 rounded-pill fw-bold" disabled>
                        Alterar Senha
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Seção Separadora: Histórico Detalhado -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <h3 class="fw-bold text-dark mb-4"><i class="bi bi-journal-text" style="color: #8a4f91;"></i> Histórico de Compras</h3>
        
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small uppercase">
                    <tr>
                        <th>Cód. Pedido</th>
                        <th>Data</th>
                        <th>Produtos</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold text-dark">#1024</td>
                        <td>25/06/2026</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="text-dark fw-semibold">Fronha Floral Rosa</span>
                                <span class="badge bg-secondary ms-2">1x</span>
                            </div>
                        </td>
                        <td class="fw-bold text-dark">R$ 29,90</td>
                        <td><span class="badge rounded-pill bg-info text-white px-3 py-2">Em Transporte</span></td>
                        <td class="text-end"><button class="btn btn-sm btn-light rounded-pill px-3">Rastrear</button></td>
                    </tr>
                    <tr>
                        <td class="fw-bold text-dark">#0987</td>
                        <td>12/05/2026</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="text-dark fw-semibold">Pano de Prato Café</span>
                                <span class="badge bg-secondary ms-2">2x</span>
                            </div>
                        </td>
                        <td class="fw-bold text-dark">R$ 39,80</td>
                        <td><span class="badge rounded-pill bg-success text-white px-3 py-2">Entregue</span></td>
                        <td class="text-end"><button class="btn btn-sm btn-light rounded-pill px-3" disabled>Concluído</button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>