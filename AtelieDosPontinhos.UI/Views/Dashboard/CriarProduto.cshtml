@model AtelieDosPontinhos.UI.Controllers.ProdutoViewModel

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4>📦 Cadastrar Novo Produto</h4>
    </div>
    <div class="card-body">

        <!-- ⚠️ IMPORTANTE: Adicionado enctype para permitir upload de arquivos -->
        <form asp-action="CriarProdutoPost" method="post" enctype="multipart/form-data">
            
            <!-- Campo: Nome do Produto -->
            <div class="form-group mb-3">
                <label class="form-label">Nome do Produto</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <!-- Campo: Preço -->
            <div class="form-group mb-3">
                <label class="form-label">Preço (R$)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" required />
            </div>

            <!-- Campo: Descrição do Produto -->
            <div class="form-group mb-3">
                <label class="form-label">Descrição do Produto</label>
                <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
            </div>

            <!-- 🖼️ MODIFICADO: Agora é um campo de arquivo do computador -->
            <div class="form-group mb-3">
                <label class="form-label">Foto do Produto</label>
                <input type="file" name="FotoArquivo" class="form-control" accept="image/*" required />
                <small class="text-muted">Selecione uma imagem (.jpg, .png, .jpeg) do seu computador.</small>
            </div>

            <!-- Campos Ocultos para Valores Padrão -->
            <input type="hidden" asp-for="Stock" value="10" />
            <input type="hidden" asp-for="CategoryId" value="1" />

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="GerenciarProdutos" class="btn btn-secondary">Voltar</a>
                <button type="submit" class="btn btn-success">Salvar Produto</button>
            </div>
        </form>

    </div>
</div>