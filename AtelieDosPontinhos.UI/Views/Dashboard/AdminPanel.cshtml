@{
    ViewData["Title"] = "Painel Admin";
}

<div class="container py-4">
    
    <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom border-2 border-white">
        <div>
            <h1 class="fw-bold text-dark mb-1">Painel Administrativo 🔐</h1>
            <p class="text-muted mb-0">Bem-vindo de volta, administrador! Gerencie o catálogo e acompanhe os dados do Ateliê.</p>
        </div>
        <div class="mx-auto bg-danger rounded" style="width: 60px; height: 4px; display: none;"></div>
    </div>

    <div class="row g-4 mb-5">
        
        <!-- CARD: VER TODOS OS PRODUTOS (CRUD principal de listagem/exclusão) -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 text-center bg-white rounded-4 transition-hover">
                <div class="fs-1 mb-2">📦</div>
                <h4 class="fw-bold text-dark">Produtos</h4>
                <p class="text-muted small">Catálogo ativo integrado</p>
                <!-- Alterado para apontar para o Dashboard que lista os produtos da API -->
                <a asp-controller="Dashboard" asp-action="GerenciarProdutos" class="btn btn-danger btn-sm rounded-pill px-4 mt-2 fw-semibold">
                    Ver Todos
                </a>
            </div>
        </div>

        <!-- CARD: CADASTRO DE NOVO PRODUTO -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 text-center bg-white rounded-4 transition-hover">
                <div class="fs-1 mb-2">➕</div>
                <h4 class="fw-bold text-dark">Novo Item</h4>
                <p class="text-muted small">Adicionar produto ao banco</p>
                <!-- Aponta para a tela de criação dentro do Dashboard ou Products -->
                <a asp-controller="Dashboard" asp-action="CriarProduto" class="btn btn-outline-secondary btn-sm rounded-pill px-4 mt-2 fw-semibold">
                    Cadastrar
                </a>
            </div>
        </div>

        <!-- CARD: VER CLIENTES CADASTRADOS -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 text-center bg-white rounded-4 transition-hover">
                <div class="fs-1 mb-2">👥</div>
                <h4 class="fw-bold text-dark">Usuários</h4>
                <p class="text-muted small">Controle de acessos e perfis</p>
                <!-- Alterado para apontar para a nova tela que lista os clientes cadastrados -->
                <a asp-controller="Dashboard" asp-action="GerenciarUsuarios" class="btn btn-outline-secondary btn-sm rounded-pill px-4 mt-2 fw-semibold">
                    Gerenciar
                </a>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow-sm p-4 rounded-4 bg-white">
        <h5 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
            <span>📢</span> Status do Sistema
        </h5>
        <div class="alert alert-success border-0 rounded-3 mb-0 bg-light text-dark d-flex align-items-center gap-3">
            <div class="fs-3">🎯</div>
            <div>
                <strong>Banco de Dados Conectado!</strong> Todas as migrações do Entity Framework Core foram aplicadas com sucesso e a carga de dados contém 26 produtos reais ativos.
            </div>
        </div>
    </div>
</div>