<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ateliê dos Pontinhos</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo/logo.png" class="logo-navbar rounded-circle me-2" alt="Logo" style="width: 40px; height: 40px; object-fit: cover;" />
                    <strong>Ateliê dos Pontinhos</strong>
                </a>

                <!-- MENU MOBILE -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- LINKS DE NAVEGAÇÃO COMPLEMENTARES -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                        </li>
                        <!-- Se o Admin estiver logado, exibe os links do CRUD que consomem a API -->
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Products" asp-action="Index">📦 Gerenciar Produtos</a>
                            </li>
                        }
                    </ul>

                    <!-- BUSCA -->
                    <div class="flex-grow-1 px-3 position-relative" style="max-width: 500px;">
                        <input type="search" class="form-control search-navbar" placeholder="Buscar produtos e categorias..." />
                        <div id="searchResults" class="list-group position-absolute w-100 mt-1" style="z-index:9999; display:none;"></div>
                    </div>

                    <!-- ÍCONES E USUÁRIO -->
                    <div class="d-flex align-items-center gap-3 fs-5 ms-auto">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="fs-6 border-end pe-2 text-muted">
                                Olá, <strong>@(User.Identity.Name ?? "usuário")</strong>
                            </span>

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Dashboard" asp-action="AdminPanel" title="Painel Admin" class="text-decoration-none">🔐</a>
                            }

                            <a asp-controller="Account" asp-action="Logout" title="Sair" class="text-decoration-none">🚪</a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" title="Minha conta" class="text-decoration-none">👤</a>
                        }

                        <!-- 🛒 CARRINHO LOCAL -->
                        <div class="position-relative" style="cursor: pointer;">
                            <span title="Carrinho">🛒</span>
                            <span class="cart-badge badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill fs-6" id="cartCount">0</span>
                        </div>

                    </div>

                </div>
            </div>
        </nav>
    </header>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- 🔎 SCRIPT DE BUSCA AJAX -->
    <script>
            const input = document.querySelector(".search-navbar");
            const resultsBox = document.getElementById("searchResults");
            let timeout = null;

            input.addEventListener("input", function () {
                clearTimeout(timeout);
                const term = this.value;

                if (term.length < 2) {
                    resultsBox.style.display = "none";
                    return;
                }

                timeout = setTimeout(async () => {
                    try {
                        // Importante: Garanta que sua API ou MVC possua essa rota mapeada
                        const response = await fetch(`/api/Product/search?term=${term}`);
                        if (!response.ok) return;

                        const data = await response.json();
                        resultsBox.innerHTML = "";

                        if (!data || data.length === 0) {
                            resultsBox.style.display = "none";
                            return;
                        }

                        data.forEach(p => {
                            const item = document.createElement("a");
                            item.classList.add("list-group-item", "list-group-item-action");
                            // Altere para a rota correta de detalhes do produto no seu MVC
                            item.href = `/Products/Details/${p.id}`;
                            item.innerText = p.name;
                            resultsBox.appendChild(item);
                        });

                        resultsBox.style.display = "block";
                    } catch (error) {
                        console.error("Erro na busca:", error);
                    }
                }, 300);
            });

            // Fechar a busca se clicar fora dela
            document.addEventListener("click", function(e) {
                if (e.target !== input && e.target !== resultsBox) {
                    resultsBox.style.display = "none";
                }
            });
    </script>

    <!-- 🛒 SCRIPT DO CARRINHO (LOCALSTORAGE) -->
    <script>
            function getCart() {
                return JSON.parse(localStorage.getItem("cart")) || [];
            }

            function updateCartCount() {
                let cart = getCart();
                let total = cart.reduce((sum, item) => sum + item.quantity, 0);
                document.getElementById("cartCount").innerText = total;
            }

            document.addEventListener("DOMContentLoaded", updateCartCount);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/cart.js"></script>
</body>
</html>
