@model List<AtelieDosPontinhos.UI.Models.ProductViewModel>

@{
    ViewData["Title"] = "Página Inicial";
}

<!-- =========================
     🎠 CAROUSEL (Banners com Bordas Arredondadas e Sombra)
========================== -->
<div class="container mt-3">
    <div id="carouselHome" class="carousel slide shadow-sm rounded-4 overflow-hidden" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/banner/banner.png" class="d-block w-100 banner-home" style="height: 400px; object-fit: cover;" alt="Banner 1" />
            </div>
            <div class="carousel-item">
                <img src="~/images/banner/Banner2.png" class="d-block w-100 banner-home" style="height: 400px; object-fit: cover;" alt="Banner 2" />
            </div>
            <div class="carousel-item">
                <img src="~/images/banner/Banner3.jpg" class="d-block w-100 banner-home" style="height: 400px; object-fit: cover;" alt="Banner 3" />
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselHome" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselHome" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </button>
    </div>
</div>