@model AtelieDosPontinhos.UI.Models.LoginViewModel

@{
    ViewData["Title"] = "Cadastrar Novo Usuário";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4 rounded-4 bg-white">
                <h2 class="fw-bold text-dark mb-4 text-center">👥 Novo Usuário</h2>
                <p class="text-muted text-center small mb-4">Registre um novo perfil de acesso ao painel do Ateliê.</p>
                
                <form asp-controller="Account" asp-action="Register" method="post">
                    
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Endereço de E-mail</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="nome@site.com" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Senha de Acesso</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Nível de Permissão</label>
                        <select class="form-select">
                            <option value="Admin" selected>Administrador 🔐</option>
                            <option value="Colaborador">Colaborador 🛠️</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Dashboard" asp-action="AdminPanel" class="btn btn-outline-secondary px-4 rounded-pill">Voltar</a>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill">Registrar Perfil</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>