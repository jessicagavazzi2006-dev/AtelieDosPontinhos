@model AtelieDosPontinhos.UI.Models.RegisterClienteViewModel

@{
    ViewData["Title"] = "Criar Minha Conta";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 p-4 rounded-4 bg-white">
                <h2 class="fw-bold mb-3 text-center" style="color: #6f42c1;">🛍️ Criar Minha Conta</h2>
                <p class="text-muted text-center small mb-4">Cadastre-se rapidamente para realizar suas compras no Ateliê.</p>
                
                <form asp-controller="Account" asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold text-secondary">Endereço de E-mail</label>
                        <input asp-for="Email" class="form-control form-control-lg bg-light border-0 fs-6" placeholder="nome@exemplo.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    @* Campo: Senha *@
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold text-secondary">Senha de Acesso</label>
                        <div class="input-group">
                            <input asp-for="Password" id="password" type="password" class="form-control form-control-lg bg-light border-0 fs-6" placeholder="Crie uma senha segura" />
                            <button class="btn btn-light border-0 bg-light" type="button" onclick="togglePassword('password', this)" style="z-index: 5;">👁️</button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    @* Campo: Confirmar Senha *@
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold text-secondary">Confirmar Senha</label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" id="confirmPassword" type="password" class="form-control form-control-lg bg-light border-0 fs-6" placeholder="Repita a senha para confirmar" />
                            <button class="btn btn-light border-0 bg-light" type="button" onclick="togglePassword('confirmPassword', this)" style="z-index: 5;">👁️</button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-lg w-100 text-white border-0 fw-bold shadow-sm mb-3" style="background-color: #6f42c1;">
                        Finalizar Cadastro
                    </button>

                    <div class="text-center">
                        <span class="text-muted small">Já tem uma conta?</span>
                        <a asp-action="Login" class="text-decoration-none small fw-bold" style="color: #6f42c1;">Fazer Login</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}